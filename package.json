{
  "name": "api-bridge-rt",
  "version": "0.1.0",
  "description": "Universal runtime API bridge — parse any API spec, execute safely, export as agent tools",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./enrichment": {
      "types": "./dist/enrichment/index.d.ts",
      "import": "./dist/enrichment/index.js",
      "require": "./dist/enrichment/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "openapi",
    "swagger",
    "api-client",
    "runtime",
    "mcp",
    "agent",
    "tool-calling",
    "universal"
  ],
  "license": "MIT",
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0"
  },
  "devDependencies": {
    "openapi-types": "^12.1.3",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
