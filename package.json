{
  "name": "api-invoke",
  "version": "0.2.1",
  "description": "Parse any API spec and execute operations — OpenAPI, raw URLs, or manual endpoints",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:e2e": "export $(grep -v '^#' .env | xargs) 2>/dev/null; vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch"
  },
  "keywords": [
    "openapi",
    "swagger",
    "api-client",
    "runtime"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jorgeroa/api-invoke.git"
  },
  "homepage": "https://github.com/jorgeroa/api-invoke#readme",
  "bugs": {
    "url": "https://github.com/jorgeroa/api-invoke/issues"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0"
  },
  "devDependencies": {
    "openapi-types": "^12.1.3",
    "tsup": "^8.0.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
